{
  "name": "mario-ppo-post20-task-conditioned-runner-4090",
  "cluster": "sandbox-sb3-mario-ppo-post20-task-runner",
  "target": "rtx4090",
  "profile_id": "mario-ppo/post20/rtx4090-task-conditioned-v1",
  "game": "SuperMarioBros-Nes-v0",
  "rom_source": "runs/skypilot_roms/SuperMarioBros-Nes-v0/rom.nes",
  "rom_mount_path": "~/roms/SuperMarioBros-Nes-v0/rom.nes",
  "extra_file_mounts": {
    "~/roms/SuperMarioBros-Nes-v0/Level1-1.state": "runs/skypilot_roms/SuperMarioBros-Nes-v0/Level1-1.state",
    "~/roms/SuperMarioBros-Nes-v0/Level1-2.state": "runs/skypilot_roms/SuperMarioBros-Nes-v0/Level1-2.state",
    "~/roms/SuperMarioBros-Nes-v0/data.json": "runs/skypilot_roms/SuperMarioBros-Nes-v0/data.json",
    "~/roms/SuperMarioBros-Nes-v0/metadata.json": "runs/skypilot_roms/SuperMarioBros-Nes-v0/metadata.json",
    "~/roms/SuperMarioBros-Nes-v0/scenario.json": "runs/skypilot_roms/SuperMarioBros-Nes-v0/scenario.json",
    "~/roms/SuperMarioBros-Nes-v0/rom.sha": "runs/skypilot_roms/SuperMarioBros-Nes-v0/rom.sha"
  },
  "stable_retro_turbo_version": "1.0.0.post21",
  "venv_name": "mario-ppo-post20-task-conditioned-runner-venv",
  "log_dir": "logs/train_runner",
  "workers": 5,
  "max_jobs": 0,
  "poll_seconds": 15,
  "status_goal": "mario-level1-1-1-2-100of100",
  "smoke": {
    "env": {
      "states": ["Level1-1", "Level1-2"],
      "state_probs": [0.5, 0.5],
      "task_conditioning": true,
      "task_conditioning_info_vars": ["levelHi", "levelLo"],
      "hud_crop_top": 32,
      "reward_mode": "score",
      "action_set": "simple",
      "done_on_info_json": "{\"life_loss\":[\"lives\",\"decrease\"],\"level_change\":[[\"levelHi\",\"levelLo\"],\"change\"]}",
      "completion_x_threshold": 0,
      "max_pool_frames": false
    }
  }
