{
  "name": "rlab-example-4090",
  "cluster": "sandbox-sb3-rlab-example",
  "target": "rtx4090",
  "game": "YourGame-Platform",
  "state": "",
  "rom_source": "roms/your-game.rom",
  "rom_mount_path": "~/roms/YourGame-Platform/your-game.rom",
  "run_name_prefix": "example_retro",
  "wandb_group_prefix": "rlab-example",
  "log_dir": "logs/rlab_example_4090",
  "venv_name": "rlab-example-venv",
  "wandb_project": "rlab",
  "wandb_tags": ["screen", "rtx4090"],
  "base_train": {
    "timesteps": 1000000,
    "n_envs": 16,
    "n_steps": 512,
    "batch_size": 512,
    "n_epochs": 10,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "ent_coef": 0.01,
    "clip_range": 0.2,
    "vf_coef": 1.0,
    "normalize_advantage": false,
    "reward_mode": "native",
    "action_set": "native",
    "frame_skip": 4,
    "max_pool_frames": true,
    "max_episode_steps": 4500,
    "completion_x_threshold": 0,
    "checkpoint_freq": 100000,
    "eval_freq": 0,
    "eval_episodes": 0,
    "device": "cuda",
    "env_threads": 4,
    "torch_num_threads": 1,
    "wandb": true,
    "wandb_mode": "online"
  },
  "runs": [
    {
      "suffix": "native_reward_seed23",
      "seed": 23,
      "learning_rate": 0.0001,
      "run_description": "Generic rlab RTX4090 run using native action space and native emulator reward. Replace game, state, ROM path, and hyperparameters for the target ROM."
    }
  ]
}
